# git-snapshot GUI defaults for this repo.
# Explicit CLI flags/URL state and env vars take precedence.

[gui "edit"]
tool = code

[gui "external-diff"]
tool = code
candidates = code,opendiff,kdiff3,meld,bcompare

[gui "compare"]
base = working-tree

[gui "snapshots"]
show-auto = false

[gui "server"]
port-start = 34757
port-count = 32
